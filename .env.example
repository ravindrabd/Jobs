# Local development defaults. On Railway these are set via the dashboard.
PORT=3001

# SQLite location. On Railway, set RAILWAY_VOLUME_MOUNT_PATH to your volume's mount path
# (e.g. /data) and the app will store jobs.db inside it for persistence across deploys.
DB_PATH=./jobs.db
# RAILWAY_VOLUME_MOUNT_PATH=/data

# Cron schedule for the scraper. Default = every 3 hours.
SCRAPE_CRON=0 */3 * * *

# Set DISABLE_CRON=1 to skip the scheduler (useful when running scrape scripts manually).
# DISABLE_CRON=1

# Chromium path inside the Docker image (Alpine).
CHROMIUM_PATH=/usr/bin/chromium-browser
